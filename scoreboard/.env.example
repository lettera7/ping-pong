# ── Copia questo file in .env per sviluppo locale ────────────────────────────
# NON committare .env (contiene valori reali)
# Usa: cp scoreboard/.env.example scoreboard/.env

# ── GoPro / stream ────────────────────────────────────────────────────────────

STREAM_MODE=live                             # "live" (GoPro) or "mock" (video locale)
GOPRO_RTSP_URL=rtsp://10.5.5.9:8554/live    # Legacy — sistema ora usa UDP via open-gopro

# ── YOLOv8 model ──────────────────────────────────────────────────────────────

YOLO_MODEL_PATH=scoreboard/models/best.pt   # Path to trained weights; falls back to yolov8n.pt
YOLO_CONF_THRESH=0.4                        # Detection confidence threshold (0.0 – 1.0)

# ── API target (Vercel deployment) ────────────────────────────────────────────

API_URL=https://ping-pong-7.vercel.app      # Base URL — no trailing slash
API_SECRET=                                  # Bearer token — must match CRON_SECRET in Vercel

# ── Players ───────────────────────────────────────────────────────────────────

PLAYER_A=Player A                           # Left side player
PLAYER_B=Player B                           # Right side player

# ── Match config ──────────────────────────────────────────────────────────────

BEST_OF=5                                   # Best of N sets (must be odd)
DEBUG=false                                 # Verbose logging

# ── Anthropic (for dev_agents.py) ─────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
