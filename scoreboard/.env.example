# Anthropic API key (used by OrchestratorAgent for score validation)
ANTHROPIC_API_KEY=sk-ant-...

# GoPro RTSP stream URL
# Default GoPro Hero WiFi hotspot: rtsp://10.5.5.9:8554/live
GOPRO_RTSP_URL=rtsp://10.5.5.9:8554/live

# Vercel /api/score endpoint
VERCEL_SCORE_URL=https://ping-pong-7.vercel.app/api/score

# Players for the current match session
PLAYER_A=Player1
PLAYER_B=Player2

# YOLOv8 model path ('yolov8n.pt' downloads the nano model automatically)
# Replace with a custom-trained model path for better digit detection accuracy
YOLO_MODEL=yolov8n.pt

# Confidence threshold for score acceptance (0.0–1.0)
SCORE_CONFIDENCE=0.7

# Seconds between frame captures
CAPTURE_INTERVAL=0.5

# Save debug frames to ./debug_frames/ (true/false)
DEBUG_FRAMES=false
