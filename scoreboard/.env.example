# ── Copia questo file in .env per sviluppo locale ────────────────────────────
# NON committare .env (contiene valori reali)
# Usa: cp scoreboard/.env.example scoreboard/.env

# ── GoPro / stream ────────────────────────────────────────────────────────────

GOPRO_RTSP_URL=rtsp://10.5.5.9:8554/live   # GoPro WiFi default RTSP endpoint (Hero 9+)
GOPRO_FPS_LIMIT=2                           # Max frames/sec to capture and process

# ── YOLOv8 model ──────────────────────────────────────────────────────────────

YOLO_MODEL_PATH=scoreboard/best.pt          # Path to fine-tuned weights; falls back to yolov8n.pt if missing
YOLO_CONF_THRESH=0.6                        # Detection confidence threshold (0.0 – 1.0)

# ── API target (Vercel deployment) ────────────────────────────────────────────

API_URL=https://ping-pong-7.vercel.app      # Base URL of the Vercel app — no trailing slash
API_SECRET=                                 # Bearer token — must match CRON_SECRET set in Vercel env vars

# ── Players ───────────────────────────────────────────────────────────────────

PLAYER_A=Player A                           # Name of the left / top player (sent in POST payload)
PLAYER_B=Player B                           # Name of the right / bottom player (sent in POST payload)

# ── Tuning ────────────────────────────────────────────────────────────────────

DEBOUNCE_FRAMES=5                           # Consecutive identical reads required before accepting a score
SCORE_RESET_THRESHOLD=3                     # Score-drop magnitude (per player) treated as a new game starting
