# ── Copia questo file in .env.local per sviluppo locale ──────────────────────
# NON committare .env.local (contiene valori reali)

# ── Frontend (VITE_ = visibili nel browser) ───────────────────────────────────

# true  → mostra banner arancione "Staging - dati di test" + usa localStorage separato
# false → comportamento produzione (default se assente)
VITE_IS_STAGING=false

# URL del Google Apps Script che restituisce i match in JSON
# Lascia vuoto per usare il valore di produzione hardcoded
VITE_SCRIPT_URL=

# ID del Google Sheet da cui leggere i match via CSV
# Lascia vuoto per usare il valore di produzione hardcoded
VITE_SHEET_ID=

# ── Backend (Vercel serverless, NON visibili nel browser) ─────────────────────

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# Nome della tabella Supabase per i bollettini
# Production → "bulletins" (default se assente)
# Staging    → "bulletins_staging"
SUPABASE_BULLETINS_TABLE=bulletins

# Google Apps Script URL per il backend (api/generate.ts)
# Lascia vuoto per usare il valore di produzione hardcoded
SCRIPT_URL=

# Anthropic (Claude per la generazione dei bollettini)
ANTHROPIC_API_KEY=sk-ant-...

# Slack webhook per notifiche di pubblicazione (opzionale)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# URL dell'app per i link nel messaggio Slack
APP_URL=https://ping-pong-7.vercel.app

# Secret per il cron job mensile (opzionale)
CRON_SECRET=
